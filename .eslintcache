ook useEffect has a missing dependency: 'actionGetCartAPI'. Either include it or remove the dependency array.",["566"],"React Hook useEffect has a missing dependency: 'actionGetCart'. Either include it or remove the dependency array.",["567"],["568"],["569"],["570"],"no-mixed-operators","Unexpected mix of '&&' and '||'.","LogicalExpression","unexpectedMixedOperator","Unexpected mix of '||' and '&&'.","React Hook useEffect has missing dependencies: 'actionGetProductId' and 'id_product'. Either include them or remove the dependency array.",["571"],"React Hook useEffect has a missing dependency: 'dataProductsEdit'. Either include it or remove the dependency array.",["572"],"React Hook useEffect has a complex expression in the dependency array. Extract it to a separate variable so it can be statically checked.","React Hook useEffect has a missing dependency: 'actionGetListProduct'. Either include it or remove the dependency array.",["573"],"no-dupe-keys","Duplicate key 'dataIndex'.","ObjectExpression","react/jsx-no-duplicate-props","No duplicate props allowed","JSXAttribute","React Hook useEffect has missing dependencies: 'dispatch', 'history', 'patchCart', 'setIdUser', 'setToken', and 'setUser'. Either include them or remove the dependency array.",["574"],"React Hook useEffect has missing dependencies: 'history' and 'patchCart'. Either include them or remove the dependency array.",["575"],"React Hook useEffect has missing dependencies: 'actionGetUsers' and 'token'. Either include them or remove the dependency array.",["576"],"React Hook useEffect has a missing dependency: 'actionGetListCommentsUser'. Either include it or remove the dependency array.",["577"],{"desc":"578","fix":"579"},{"desc":"580","fix":"581"},{"desc":"582","fix":"583"},{"desc":"584","fix":"585"},{"desc":"586","fix":"587"},{"desc":"588","fix":"589"},{"desc":"590","fix":"591"},{"desc":"592","fix":"593"},{"desc":"594","fix":"595"},{"desc":"596","fix":"597"},{"desc":"598","fix":"599"},{"desc":"600","fix"