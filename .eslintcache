uter scope values like 'tokenLocal' aren't valid dependencies because mutating them doesn't re-render the component.",["576"],"React Hook useEffect has missing dependencies: 'actionGetProductAll', 'actionGetProductSlider', and 'actionGetProductType'. Either include them or remove the dependency array.",["577"],"jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","React Hook useEffect has a missing dependency: 'form'. Either include it or remove the dependency array.",["578"],["579"],"eqeqeq","Expected '===' and instead saw '=='.","BinaryExpression","unexpected","React Hook useEffect has a missing dependency: 'setUser'. Either include it or remove the dependency array. If 'setUser' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["580"],"React Hook useEffect has missing dependencies: 'history', 'idProduct', and 'socket'. Either include them or remove the dependency array.",["581"],["582"],["583"],["584"],["585"],"React Hook useEffect has a missing dependency: 'actionGetCartAPI'. Either include it or remove the dependency array.",["586"],"React Hook useEffect has a missing dependency: 'actionGetCart'. Either include it or remove the dependency array.",["587"],["588"],["589"],["590"],"no-mixed-operators","Unexpected mix of '&&' and '||'.","LogicalExpression","unexpectedMixedOperator","Unexpected mix of '||' and '&&'.","React Hook useEffect has missing dependencies: 'actionGetProductId' and 'id_product'. Either include them or remove the dependency array.",["591"],"React Hook useEffect has a missing dependency: 'dataProductsEdit'. Either include it or remove the dependency array.",["592"],"React Hook useEffect has a complex expression in the dependency array. Extract it to a separate variable so it can be statically checked.","no-unused-vars","'Button' is defined but never used.","Identifier","unusedVar","React Hook useEffect has a missing dependency: 'actionGetListProduct'. Either include it or remove the dependency array.",["593"],"no-dupe-keys","Duplicate key 'dataIndex'.","ObjectExpression","react/jsx-no-duplicate-props","No duplicate props allowed","JSXAttribute","React Hook useEffect has missing dependencies: 'dispatch', 'history', 'patchCart', 'setIdUser', 'setToken', and 'setUser'. Either include them or remove the dependency array.",["594"],"React Hook useEffect has missing dependencies: 'history' and 'patchCart'. Either include them or remove the dependency array.",["595"],"'setPageCMT' is assigned a value but never used.","React Hook useEffect has missing dependencies: 'actionGetUsers' and 'token'. Either include them or remove the dependency array.",["596"],"React Hook useEffect has a missing dependency: 'actionGetListCommentsUser'. Either include it or remove the dependency array.",["597"],{"desc":"598","fix":"599"},{"desc":"600","fix":"601"},{"desc":"602","fix":"603"},{"desc":"604","fix":"605"},{"desc":"606","fix":"607"},{"desc":"608","fix":"609"},{"desc":"610","fix":"611"},{"desc":"612","fix":"613"},{"desc":"614","fix":"615"},{"desc":"616","fix":"617"},{"desc":"618","fix":"619"},{"desc":"620","fix":"621"},{"desc":"622","fix":"623"},{"desc":"624","fix":"625"},{"desc":"626","fix":"627"},{"desc":"628","fix":"629"},{"desc":"630","fix":"631"},{"desc":"632","fix":"633"},{"desc":"634","fix":"635"},{"desc":"636","fix":"637"},{"desc":"630","fix":"638"},{"desc":"632","fix":"639"},{"desc":"634","fix":"640"},{"desc":"620","fix":"641"},{"desc":"642","fix":"643"},{"desc":"644","fix":"645"},{"desc":"6